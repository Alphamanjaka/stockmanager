APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Utiliser pgsql au lieu de mysql
DB_CONNECTION=pgsql
# L'hôte est le nom du service Docker, pas 127.0.0.1
DB_HOST=postgres
# Le port exposé par le service postgres
DB_PORT=${POSTGRES_PORT:-5432}
# Les identifiants définis dans compose.dev.yaml
DB_DATABASE=app
DB_USERNAME=laravel
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
#...

# TODO: Vérifiez que le nom du dossier correspond bien à votre version dans C:\laragon\bin\postgresql\
PGDUMP_PATH="C:\\laragon\\bin\\postgresql\\postgresql\\bin"


BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# L'hôte Redis est aussi le nom du service Docker
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Looking to send emails in production? Check out our Email API/SMTP product!
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=17e755f1fb82d2
MAIL_PASSWORD=7abf1a22d1d3d1
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="alerte@vitrine.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sync user ID and group ID to avoid permission issues on development
UID=197609  # Replace with your user ID
GID=197609  # Replace with your group ID
NODE_VERSION=25 # ou 25 si vous voulez la toute dernière

API_KEY_TOKEN=12748e534f9fbc84b90f1cec23e1fe54
